\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{general-math}[2026/06/28 General Math and Linking Setup]

% Main packages
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{amsmath, amssymb, amsthm, amsfonts, mathrsfs}
\RequirePackage{graphicx, physics, enumitem, geometry, esint}
\RequirePackage{twemojis, tikz, quiver}

\geometry{margin=1in}

% Colored links
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage[colorlinks=true,
            linkcolor=OliveGreen,
            citecolor=OliveGreen]{hyperref}

% Math Macros
