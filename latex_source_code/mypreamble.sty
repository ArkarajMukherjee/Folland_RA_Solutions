\def\bZ{\mathbb{Z}}
\def\bQ{\mathbb{Q}}
\def\bR{\mathbb{R}}
\def\bC{\mathbb{C}}
\def\bE{\mathbb{E}}
\def\bF{\mathbb{F}}
\def\bK{\mathbb{K}}

\def\mB{\mathcal{B}}
\def\mM{\mathcal{M}}
\def\mR{\mathcal{R}}
\def\mN{\mathcal{N}}
\def\mE{\mathcal{E}}
\def\mA{\mathcal{A}}
\def\mL{\mathcal{L}}

% Operators
\def\d{\,\mathrm{d}}
\def\supp{\operatorname{supp}}
\def\sgn{\operatorname{sgn}}
\def\argmax{\mathop{\mathrm{argmax}}\limits}
\def\argmin{\mathop{\mathrm{argmin}}\limits}
